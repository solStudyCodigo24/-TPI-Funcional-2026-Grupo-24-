(defun timer (tiempo-unix)
   (let ((segundo (rem tiempo-unix 216)))
      (cond
         ((and (>= segundo 0) (<= segundo 89)) 'en-rojo)
         ((and (>= segundo 90) (<= segundo 95)) 'en-amarillo)
         ((and (>= segundo 96) (<= segundo 215)) 'en-verde))))


