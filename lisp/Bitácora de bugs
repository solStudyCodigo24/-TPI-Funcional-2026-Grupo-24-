(defun calculaPorcentajesHora (rojo amarillo verde)
  (let ((totalSegundos (+ rojo amarillo verde)))
   (list
       'ROJO (float(* (/ rojo totalSegundos) 100))
       'AMARILLO (float (* (/ amarillo totalSegundos) 100))
       'VERDE (float(* (/ verde totalSegundos) 100)))))

(defun informe-error-stream (datos)
